# Copia este archivo a .env.local y rellena tus claves.

# --- OBLIGATORIO: Groq (motor del chatbot) ---
# Consíguela gratis en https://console.groq.com/keys
GROQ_API_KEY=
# Modelo de Groq (opcional, por defecto llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# --- OPCIONAL: Upstash Redis (límite de peticiones por IP) ---
# Si las dejas vacías, el chatbot funciona igual pero SIN límite por IP.
# Crea una base de datos gratis en https://console.upstash.com (Redis)
# y copia las credenciales "REST".
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
